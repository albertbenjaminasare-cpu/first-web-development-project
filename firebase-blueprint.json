{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores customer profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "Customer email" },
        "displayName": { "type": "string", "description": "Customer name" },
        "photoURL": { "type": "string", "description": "Profile picture URL" },
        "role": { "type": "string", "enum": ["admin", "customer"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation time" }
      },
      "required": ["uid", "email", "role"]
    },
    "OrderInterest": {
      "title": "Order Interest",
      "description": "Stores customer interest in specific items.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Interest ID" },
        "customerUid": { "type": "string", "description": "UID of the customer" },
        "customerEmail": { "type": "string", "format": "email", "description": "Email of the customer" },
        "itemType": { "type": "string", "description": "The type of item the customer wants" },
        "productId": { "type": "string", "description": "Specific product ID if applicable" },
        "productName": { "type": "string", "description": "Name of the product" },
        "status": { "type": "string", "enum": ["pending", "contacted", "completed"], "description": "Status of the interest" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Time of submission" }
      },
      "required": ["customerUid", "customerEmail", "itemType", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "Stores chat messages between Nicho and customers.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Message ID" },
        "senderUid": { "type": "string", "description": "UID of the sender" },
        "receiverUid": { "type": "string", "description": "UID of the receiver (Nicho or Customer)" },
        "text": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Time of message" }
      },
      "required": ["senderUid", "receiverUid", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/interests/{interestId}": {
      "schema": "OrderInterest",
      "description": "Customer interests and order requests."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific chat session."
    }
  }
}
